nomad {
  address = "{{ nomad_server_address }}"
  namespace = ["*"]
  # For explicit namespace list instead of wildcard, use e.g. ["default", "ns1", "ns2"].
}

apm "influxdb" {
  driver = "influxdb"
  config = {
    address  = "{{ influxdb_apm_address }}"
    database = "{{ influxdb_apm_database }}"
    username = "{{ influxdb_autoscaler_user }}"
    password = "{{ influxdb_autoscaler_password }}"
  }
}

strategy "target-value" {
  driver = "target-value"
}
