# InfluxDB Configuration
# This file is auto-generated by Ansible - do not edit manually

[meta]
  dir = "{{ influxdb_data_dir }}/meta"

[data]
  dir = "{{ influxdb_data_dir }}/data"
  wal-dir = "{{ influxdb_data_dir }}/wal"
  cache-max-memory-bytes = 1073741824
  cache-snapshot-memory-bytes = 26214400
  cache-snapshot-write-cold-duration = "10m0s"
  compact-full-write-cold-duration = "4h0m0s"
  max-concurrent-compactions = 0
  compact-throughput = 52428800
  compact-throughput-burst = 52428800

[[retention]]
  enabled = true
  check-interval = "30m0s"

[http]
  enabled = true
  bind-address = "0.0.0.0:8086"
  auth-enabled = {{ influxdb_auth_enabled | lower }}
  realm = "InfluxDB"
  log-enabled = true
  suppress-write-log = false
  write-tracing = false
  pprof-enabled = true
  https-enabled = false
  max-body-size = 25000000
  max-concurrent-write-limit = 0
  max-enqueued-write-limit = 0
  enqueued-write-timeout = "30s"
  enable-gzip-encoding = true

[[graphite]]
  enabled = false

[[collectd]]
  enabled = false

[[opentsdb]]
  enabled = false

[[udp]]
  enabled = false

[monitoring]
  enabled = true
  write-interval = "30s"

[subscriber]
  enabled = true
  http-timeout = "30s"
  insecure-skip-verify = false
  ca-certs = ""
  write-concurrency = 40
  write-buffer-size = 1000

[logging]
  format = "auto"
  level = "info"

[continuous_queries]
  log-enabled = true
  enabled = true
  run-interval = "1s"
